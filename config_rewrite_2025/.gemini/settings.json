{
  "context": {
    "fileFiltering": {
      "enableRecursiveFileSearch": false
    }
  },
  "general": {
    "preferredEditor": "vim",
    "enablePromptCompletion": true,
    "vimMode": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "120d"
    }
  },
  "experimental": { "enableAgents": true },
  "ui": {
    "theme": "Dracula",
    "customWittyPhrases": [
      "thinking"
    ],
    "__useFullWidth": true,
    "__useAlternateBuffer": true,
    "accessibility": {
      "enableLoadingPhrases": false
    },
    "loadingPhrases": "off"
  }
}
