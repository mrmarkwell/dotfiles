{
    "context": {
        "fileFiltering": {
            "enableRecursiveFileSearch": false
        }
    },
    "general": {
        "preferredEditor": "vim",
        "enablePromptCompletion": true,
        "vimMode": true
    },
    "ui": {
        "theme": "Dracula",
        "customWittyPhrases": [
            "thinking"
        ],
        "__useFullWidth": true,
        "__useAlternateBuffer": true,
        "accessibility": {
            "disableLoadingPhrases": true
        }
    },
    "tools": {
        "core": [
            "run_shell_comand(blaze build)",
            "run_shell_comand(blaze test)",
            "run_shell_comand(blaze run)",
            "run_shell_comand(hg diff)",
            "run_shell_comand(hg pdiff)",
            "run_shell_comand(hg status)",
            "run_shell_comand(hg pstatus)",
            "run_shell_comand(build_cleaner)",
            "search_for_files_codesearch"
        ]
    }
}
